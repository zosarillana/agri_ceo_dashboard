t"},{"id":"energy_input_form_inputskeleton","label":"InputSkeleton()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L113-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L113"}],"snippet":"function InputSkeleton() {\n  return (\n    <div className=\"grid md:grid-cols-2 gap-3\">\n      {[0, 1].map((i) => (\n        <Card key={i}>\n          <CardContent className=\"pt-4 pb-4 space-y-3\">\n            <div className=\"flex items-baseline justify-between\">\n              <Skeleton className=\"h-4 w-24\" />\n              <Skeleton className=\"h-3 w-12\" />\n            </div>\n            <Skeleton className=\"h-9 w-full rounded-md\" />\n            <Skeleton className=\"h-9 w-full rounded-md\" />\n            <Skeleton className=\"h-9 w-full rounded-md\" />\n          </CardContent>\n        </Card>\n      ))}\n    </div>\n  );\n}","node_kind":"component"},{"id":"energy_input_form_energyinputform","label":"EnergyInputForm()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L135-L621","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L135"}],"snippet":"export default function EnergyInputForm({ onSaved }: Props) {\n  const today = getTodayMonth();\n\n  const { data, fetchByMonth, saveBulk, saving } = useEnergyStore();\n\n  const [monthISO, setMonthISO]     = useState(today);\n  const [calOpen, setCalOpen]       = useState(false);\n  const [rows, setRows]             = useState<InputRows>(emptyInputRows());\n  const [fetchingRows, setFetchingRows] = useState(false);\n  const [status, setStatus]         = useState<\"idle\" | \"success\" | \"error\">(\"idle\");\n  const [statusMsg, setStatusMsg]   = useState(\"\");\n\n  // Track which accounts have been manually unlocked for editing\n  const [unlockedKeys, setUnlockedKeys] = useState<Set<AccountKey>>(new Set());\n\n  // Display values for formatted numbers\n  const [displayValues, setDisplayValues] = useState<Record<AccountKey, { kw: string; demand: string; billedAmount: string }>>({\n    account2: { kw: \"\", demand: \"\", billedAmount: \"\" },\n    account3: { kw: \"\", demand: \"\", billedAmount: \"\" },\n  });\n\n  // Cache raw data per month so we can restore on relock\n  const cache = useRef<Record<string, InputRows>>({});\n\n  /* ───────────────────────────────────────────── */","node_kind":"function","framework":"nextjs","framework_role":"next_client_component","runtime_boundary":"client"},{"id":"energy_input_form_energyinputform_maprecord","label":"mapRecord()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L195-L206","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L195"}],"snippet":"function mapRecord(account: AccountKey): InputRow {\n    const record = data?.[account]?.find(\n      (r) => r.billing_month.slice(0, 7) === monthISO,\n    );\n    const hasData = record && (record.kw > 0 || record.billed_amount > 0);\n    return {\n      kw:           record ? String(record.kw)            : \"\",\n      demand:       record ? String(record.demand)         : \"\",\n      billedAmount: record ? String(record.billed_amount)  : \"\",\n      isReadOnly:   !!hasData,\n    };\n  }"},{"id":"energy_input_form_energyinputform_loadmonth","label":"loadMonth()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L210-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L210"}],"snippet":"async function loadMonth(iso: string) {\n    setMonthISO(iso);\n    setStatus(\"idle\");\n    setStatusMsg(\"\");\n    setUnlockedKeys(new Set());\n\n    if (cache.current[iso]) {\n      setRows(cache.current[iso]);\n      return;\n    }\n\n    setFetchingRows(true);\n    await fetchByMonth(iso);\n    // rows are set via the useEffect above when `data` updates\n  }"},{"id":"energy_input_form_energyinputform_handlemonthselect","label":"handleMonthSelect()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L226-L231","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L226"}],"snippet":"function handleMonthSelect(d: Date | undefined) {\n    if (!d) return;\n    const iso = d.toLocaleDateString(\"en-CA\").slice(0, 7);\n    loadMonth(iso);\n    setCalOpen(false);\n  }"},{"id":"energy_input_form_energyinputform_setfield","label":"setField()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L233-L255","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L233"}],"snippet":"function setField(\n    account: AccountKey,\n    field: keyof Omit<InputRow, \"isReadOnly\">,\n    formattedValue: string,\n  ) {\n    if (rows[account].isReadOnly && !unlockedKeys.has(account)) return;\n    \n    // Remove commas to get raw number\n    const rawValue = formattedValue.replace(/,/g, '');\n    \n    setRows((r) => ({ ...r, [account]: { ...r[account], [field]: rawValue } }));\n    \n    // Update display value with formatted version\n    setDisplayValues(prev => ({\n      ...prev,\n      [account]: {\n        ...prev[account],\n        [field]: formattedValue\n      }\n    }));\n    \n    setStatus(\"idle\");\n  }"},{"id":"energy_input_form_energyinputform_handleblur","label":"handleBlur()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L257-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L257"}],"snippet":"function handleBlur(account: AccountKey, field: keyof Omit<InputRow, \"isReadOnly\">) {\n    const row = rows[account];\n    if (row) {\n      const value = row[field];\n      const formatted = formatDisplayValue(value);\n      setDisplayValues(prev => ({\n        ...prev,\n        [account]: {\n          ...prev[account],\n          [field]: formatted\n        }\n      }));\n    }\n  }"},{"id":"energy_input_form_energyinputform_handlefocus","label":"handleFocus()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L272-L284","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L272"}],"snippet":"function handleFocus(account: AccountKey, field: keyof Omit<InputRow, \"isReadOnly\">) {\n    const row = rows[account];\n    if (row) {\n      const rawValue = row[field];\n      setDisplayValues(prev => ({\n        ...prev,\n        [account]: {\n          ...prev[account],\n          [field]: rawValue\n        }\n      }));\n    }\n  }"},{"id":"energy_input_form_energyinputform_unlockaccount","label":"unlockAccount()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L289-L297","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L289"}],"snippet":"function unlockAccount(key: AccountKey) {\n    setUnlockedKeys((prev) => new Set(prev).add(key));\n    setRows((prev) => ({\n      ...prev,\n      [key]: { ...prev[key], isReadOnly: false },\n    }));\n    setStatus(\"idle\");\n    setStatusMsg(\"\");\n  }"},{"id":"energy_input_form_energyinputform_relockaccount","label":"relockAccount()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L299-L321","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L299"}],"snippet":"function relockAccount(key: AccountKey) {\n    setUnlockedKeys((prev) => {\n      const next = new Set(prev);\n      next.delete(key);\n      return next;\n    });\n\n    // Restore values from cache\n    const cached = cache.current[monthISO];\n    if (cached?.[key]) {\n      setRows((prev) => ({\n        ...prev,\n        [key]: { ...cached[key], isReadOnly: true },\n      }));\n    } else {\n      setRows((prev) => ({\n        ...prev,\n        [key]: { kw: \"\", demand: \"\", billedAmount: \"\", isReadOnly: false },\n      }));\n    }\n    setStatus(\"idle\");\n    setStatusMsg(\"\");\n  }"},{"id":"energy_input_form_energyinputform_handlereset","label":"handleReset()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L323-L333","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L323"}],"snippet":"function handleReset() {\n    const cached = cache.current[monthISO];\n    if (cached) {\n      setRows(cached);\n    } else {\n      setRows(emptyInputRows());\n    }\n    setUnlockedKeys(new Set());\n    setStatus(\"idle\");\n    setStatusMsg(\"\");\n  }"},{"id":"energy_input_form_energyinputform_handlesave","label":"handleSave()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L337-L393","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L337"}],"snippet":"async function handleSave(e: React.FormEvent) {\n    e.preventDefault();\n\n    const keys: AccountKey[] = [\"account2\", \"account3\"];\n\n    const payload: EnergyPayload[] = keys\n      .filter((k) => {\n        // Save if: unlocked (update) OR editable with values (create)\n        if (unlockedKeys.has(k)) return true;\n        if (!rows[k].isReadOnly) {\n          const kw = parseFloat(rows[k].kw) || 0;\n          const ba = parseFloat(rows[k].billedAmount) || 0;\n          return kw > 0 || ba > 0;\n        }\n        return false;\n      })\n      .map((k) => ({\n        account:       k,\n        month:         monthISO,\n        kw:            parseFloat(rows[k].kw)            || 0,\n        demand:        parseFloat(rows[k].demand)         || 0,\n        billedAmount:  parseFloat(rows[k].billedAmount)   || 0,\n      }));\n\n    if (!payload.length) {"}],"e