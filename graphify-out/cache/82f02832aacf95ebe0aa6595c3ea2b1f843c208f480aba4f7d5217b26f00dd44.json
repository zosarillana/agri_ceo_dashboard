LocaleDateString(\"en-CA\").slice(0, 7);\n}"},{"id":"energy_input_form_isotodate","label":"isoToDate()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L53-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L53"}],"snippet":"function isoToDate(iso: string) {\n  const [y, m] = iso.split(\"-\").map(Number);\n  return new Date(y, m - 1, 1);\n}"},{"id":"energy_input_form_emptyinputrows","label":"emptyInputRows()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L58-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L58"}],"snippet":"function emptyInputRows(): InputRows {\n  return {\n    account2: { kw: \"\", demand: \"\", billedAmount: \"\", isReadOnly: false },\n    account3: { kw: \"\", demand: \"\", billedAmount: \"\", isReadOnly: false },\n  };\n}"},{"id":"energy_input_form_formatdisplayvalue","label":"formatDisplayValue()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L66-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/routes/auth/-components/-forms/energy-input-form.tsx","source_location":"L66"}],"snippet":"function formatDisplayValue(value: string | number): string {\n  if (value === \"\" || value === null || value === undefined) return \"\";\n  \n  // Convert to number\n  let num = typeof value === 'string' ? parseFloat(value) : value;\n  \n  // Return