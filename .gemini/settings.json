{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "read_file|list_directory|search_for_pattern",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var f;try{require('fs').accessSync('graphify-out/graph.json');f=''}catch(e){f='eyJkZWNpc2lvbiI6ImFsbG93In0='}process.stdout.write(Buffer.from(f,'base64').toString())\""
          }
        ]
      }
    ]
  }
}
