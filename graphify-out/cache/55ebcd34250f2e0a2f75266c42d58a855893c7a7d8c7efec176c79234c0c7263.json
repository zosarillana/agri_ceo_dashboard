t\";\n  const userEmail = user?.email ?? \"\";\n\n  const logoTo =\n    isAuthenticated && user ? getDashboardRouteByRole(user.role) : \"/\";\n\n  const handleSignOut = async () => {\n    try {\n      await logout();\n\n      // optional: clear any local auth state\n      // e.g. zustand / redux / context\n      // authStore.setState({ user: null, isAuthenticated: false });\n\n      navigate({ to: \"/\" });\n    } catch (error) {\n      console.error(\"Logout failed:\", error);\n    }","node_kind":"component"},{"id":"nav_bar_globalnavbar_handlesignout","label":"handleSignOut()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/components/global/nav-bar.tsx","source_location":"L73-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/components/global/nav-bar.tsx","source_location":"L73"}],"snippet":"handleSignOut = async () => {\n    try {\n      await logout();\n\n      // optional: clear any local auth state\n      // e.g. zustand / redux / context\n      // authStore.setState({ user: null, isAuthenticated: false });\n\n      navigate({ to: \"/\" });\n    } catch (error) {\n      console.error(\"Logout failed:\", error);\n    }\n  }"},{"id":"nav_bar_globalnavbar_handlenavigate","label":"handleNavigate()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/components/global/nav-bar.tsx","source_location":"L87-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"D:/Projects/agri_ceo_dashboard/src/components/global/nav-bar.tsx","source_location":"L87"}],"snippet":"handleNavigate = (path: string) => {\n    navigate({ to: path as any });\n  }"},{"id":"nav_bar_globalnavbar_getinitials","label":"getInitials()","file_type":"code","source_file":"D:/Projects/agri_ceo_dashboard/src/components/global/nav-bar.tsx","source_location":"L91-L98","layer":"base","provenance":[{"capability_id":"bu